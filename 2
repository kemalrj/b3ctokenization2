                overflow: hidden;
                transition: all 0.3s ease;
              }
              .coin-usdt { background: linear-gradient(135deg, #065f46, #047857); color: white; }
              .coin-usdc { background: linear-gradient(135deg, #1e3a8a, #1d4ed8); color: white; }
              .coin-card:hover { transform: translateY(-6px); }

              .map-pin {
                position: absolute;
                transform: translate(-50%, -100%);
                cursor: pointer;
                transition: all 0.3s ease;
