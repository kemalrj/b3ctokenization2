              }
              .badge {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                padding: 5px 14px;
                border-radius: 100px;
                font-size: 11px;
                font-weight: 700;
                letter-spacing: 0.06em;
                text-transform: uppercase;
              }
              .badge-purple-dark { background: rgba(167,139,250,0.12); border: 1px solid rgba(167,139,250,0.3); color: #c4b5fd; }
              .badge-purple-light { background: rgba(124,58,237,0.1); border: 1px solid rgba(124,58,237,0.25); color: var(--violet); }
              .badge-gold-dark { background: rgba(245,158,11,0.12); border: 1px solid rgba(245,158,11,0.3); color: #fbbf24; }
              .badge-gold-light { background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.25); color: #d97706; }
              .badge-green { background: rgba(16,185,129,0.12); border: 1px solid rgba(16,185,129,0.3); color: #34d399; }
              .badge-green-light { background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.2); color: #059669; }
              .input-dark {
                background: rgba(255,255,255,0.05);
                border: 1px solid rgba(167,139,250,0.2);
                border-radius: 10px;
                color: var(--text-light);
                padding: 12px 16px;
                font-size: 14px;
                transition: all 0.3s ease;
                outline: none;
                width: 100%;
              }
              .input-dark:focus { border-color: rgba(139,92,246,0.5); box-shadow: 0 0 0 3px rgba(124,58,237,0.12); }
              .progress-bar-light { height: 6px; background: rgba(109,40,217,0.1); border-radius: 3px; overflow: hidden; }
              .progress-fill-light { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--violet), var(--purple)); }
              .section-padding { padding: 100px 0; }
              .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
              .section-header { text-align: center; margin-bottom: 64px; }

              .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
              .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
              .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
              @media (max-width: 1024px) { .grid-4 { grid-template-columns: repeat(2, 1fr); } }
              @media (max-width: 768px) { .grid-3 { grid-template-columns: repeat(2, 1fr); } .grid-2 { grid-template-columns: 1fr; } }
              @media (max-width: 480px) { .grid-3, .grid-4 { grid-template-columns: 1fr; } }

              .animate-float { animation: float 6s ease-in-out infinite; }
              .animate-spin-slow { animation: spin-slow 20s linear infinite; }
              .animate-slide-up { animation: slide-up 0.6s ease forwards; }

              @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-16px); } }
              @keyframes spin-slow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
              @keyframes slide-up { from { opacity: 0; transform: translateY(24px); } to { opacity: 1; transform: translateY(0); } }
              @keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
              @keyframes pulse-ring { 0% { transform: translate(-50%,-50%) scale(1); opacity: 0.6; } 100% { transform: translate(-50%,-50%) scale(2); opacity: 0; } }
              @keyframes scroll-x { from { transform: translateX(0); } to { transform: translateX(-50%); } }

              .grid-bg-dark {
                background-image: linear-gradient(rgba(124,58,237,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(124,58,237,0.06) 1px, transparent 1px);
                background-size: 50px 50px;
              }
              .grid-bg-light {
                background-image: linear-gradient(rgba(109,40,217,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(109,40,217,0.05) 1px, transparent 1px);
                background-size: 40px 40px;
              }
              .divider-light { height: 1px; background: linear-gradient(90deg, transparent, rgba(109,40,217,0.12), transparent); }
