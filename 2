          }} />
        );

        /* ==========================================================================
           2. NAVBAR COMPONENT
           ========================================================================== */
        function Navbar() {
          const [scrolled, setScrolled] = useState(false);
          const [mobileOpen, setMobileOpen] = useState(false);

          useEffect(() => {
            const onScroll = () => setScrolled(window.scrollY > 40);
            window.addEventListener("scroll", onScroll);
            return () => window.removeEventListener("scroll", onScroll);
          }, []);

          const nav = (href) => {
            setMobileOpen(false);
            const el = document.querySelector(href);
            if (el) el.scrollIntoView({ behavior: "smooth" });
          };

          return (
            <>
              <nav style={{
                position: "fixed", top: 0, left: 0, right: 0, zIndex: 100,
                transition: "all 0.4s ease",
                background: scrolled ? "rgba(15,5,32,0.96)" : "transparent",
                backdropFilter: scrolled ? "blur(24px)" : "none",
                borderBottom: scrolled ? "1px solid rgba(167,139,250,0.1)" : "none",
                boxShadow: scrolled ? "0 4px 30px rgba(124,58,237,0.15)" : "none",
              }}>
                <div className="container" style={{ display: "flex", alignItems: "center", justifyContent: "space-between", padding: "16px 24px" }}>
                  <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
                    <div style={{
                      width: 42, height: 42, borderRadius: 12,
                      background: "linear-gradient(135deg, #7c3aed, #a855f7)",
                      display: "flex", alignItems: "center", justifyContent: "center",
                      boxShadow: "0 4px 16px rgba(124,58,237,0.4)",
                    }}>
                      <span style={{ fontFamily: "Space Grotesk", fontWeight: 900, fontSize: 15, color: "#fff" }}>B3C</span>
                    </div>
                    <div>
                      <div style={{ fontFamily: "Space Grotesk", fontWeight: 900, fontSize: 20, color: "#fff" }}>B3C</div>
                      <div style={{ fontSize: 9, color: "rgba(196,181,253,0.7)", fontWeight: 600, letterSpacing: "0.1em", marginTop: -2 }}>TOKENIZASYON</div>
                    </div>
                  </div>

                  <div style={{ display: "flex", gap: 4, alignItems: "center" }} className="hidden lg:flex">
                    {[
                      { label: "Nedir?", href: "#nedir" },
                      { label: "Varlıklar", href: "#varliklar" },
                      { label: "Harita", href: "#harita" },
                      { label: "Demo", href: "#demo" },
                      { label: "SSS", href: "#sss" },
                      { label: "İletişim", href: "#iletisim" },
                    ].map((l) => (
                      <button key={l.href} onClick={() => nav(l.href)} style={{
                        background: "none", border: "none", color: "rgba(221,214,254,0.8)",
                        fontSize: 14, fontWeight: 500, cursor: "pointer", padding: "8px 14px", borderRadius: 8,
                        transition: "all 0.2s ease",
                      }}
                        onMouseEnter={(e) => { e.target.style.color = "#fff"; e.target.style.background = "rgba(167,139,250,0.1)"; }}
                        onMouseLeave={(e) => { e.target.style.color = "rgba(221,214,254,0.8)"; e.target.style.background = "none"; }}
                      >{l.label}</button>
                    ))}
                  </div>

                  <div style={{ display: "flex", gap: 10, alignItems: "center" }} className="hidden lg:flex">
                    <div className="badge badge-gold-dark">✦ DEMO</div>
                    <button className="btn-primary" style={{ padding: "10px 20px", fontSize: 13 }} onClick={() => nav("#demo")}>
                      Demo Başlat →
                    </button>
                  </div>

                  <button className="lg:hidden" onClick={() => setMobileOpen(!mobileOpen)}
                    style={{ background: "none", border: "none", color: "#fff", cursor: "pointer", padding: 8 }}>
                    {mobileOpen ? <X size={24} /> : <Menu size={24} />}
                  </button>
                </div>
              </nav>

              {mobileOpen && (
                <div style={{ position: "fixed", inset: 0, zIndex: 90, background: "rgba(15,5,32,0.98)", backdropFilter: "blur(24px)", paddingTop: 80 }}>
                  <div style={{ padding: "16px 24px", display: "flex", flexDirection: "column", gap: 4 }}>
                    {[
                      { label: "Nedir?", href: "#nedir" },
                      { label: "Varlıklar", href: "#varliklar" },
                      { label: "Harita", href: "#harita" },
                      { label: "Demo", href: "#demo" },
                      { label: "SSS", href: "#sss" },
                      { label: "İletişim", href: "#iletisim" },
                    ].map((l) => (
                      <button key={l.href} onClick={() => nav(l.href)} style={{
                        background: "none", border: "none", borderBottom: "1px solid rgba(167,139,250,0.1)",
                        color: "#e9d5ff", fontSize: 18, fontWeight: 500, cursor: "pointer",
                        padding: "18px 0", textAlign: "left",
                      }}>{l.label}</button>
                    ))}
                    <button className="btn-primary" style={{ marginTop: 16, width: "100%", justifyContent: "center" }} onClick={() => nav("#demo")}>
                      Demo Başlat →
                    </button>
                  </div>
                </div>
              )}
            </>
          );
        }
